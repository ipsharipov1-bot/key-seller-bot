# VanessPay Bot - Конфигурация

# Токен бота от @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Username менеджера (без @)
MANAGER_USERNAME=your_manager_username

# Telegram ID менеджера для доступа к админке (получить: @userinfobot)
MANAGER_ID=your_telegram_user_id_here

# Ссылка на Telegram канал для подписки
CHANNEL_LINK=https://t.me/your_channel

# Ссылка на страницу оплаты
PAYMENT_LINK=https://t.me/your_manager_username
